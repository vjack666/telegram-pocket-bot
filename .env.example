APP_LOG_LEVEL=INFO
APP_DRY_RUN=true
APP_DEFAULT_AMOUNT=1.0
APP_DEFAULT_ASSET=EURUSD OTC
APP_ENABLE_TELEGRAM=false
APP_EXPECTED_UTC_OFFSET_HOURS=-3
APP_ENFORCE_UTC_OFFSET=false
APP_SIGNAL_TIMEZONE=America/Argentina/Buenos_Aires
APP_SIGNAL_LATE_TOLERANCE_SECONDS=300
APP_PROCESSING_QUEUE_MAXSIZE=500
APP_MESSAGE_DEDUPE_TTL_SECONDS=21600
APP_BUSY_POLICY=queue
APP_SINGLE_ASSET_MODE=false
APP_MARTINGALE_AMOUNTS=2,4,10
APP_MARTINGALE_MODE=fixed
APP_CALC_PAYOUT_PERCENT=92
APP_CALC_INCREMENT=2
APP_CALC_RULE10_BALANCE_THRESHOLD=50
APP_CALC_MAX_STEPS=3
APP_ORDER_RESULT_GRACE_SECONDS=15
APP_COLOR_OUTPUT=true

# Blackbox / observabilidad (jsonl en runtime/blackbox)
# Ajustes de retención y recorte definidos en main.py.

# demo | real (solo etiqueta interna para tu experimento)
POCKET_ACCOUNT_MODE=demo
POCKET_DEMO_URL=https://pocketoption.com/en/cabinet/demo-quick-high-low/
POCKET_PROFILE_DIR=.pocket_profile
POCKET_HEADLESS=false
POCKET_EXECUTE_ORDERS=false
POCKET_MAX_ORDER_AMOUNT=5
POCKET_BALANCE_WAIT_SECONDS=240
POCKET_KEEP_BROWSER_OPEN=true
POCKET_BALANCE_SELECTOR=
POCKET_ASSET_OPEN_SELECTOR=
POCKET_ASSET_SEARCH_SELECTOR=
POCKET_ASSET_RESULT_SELECTOR=
POCKET_BUY_SELECTOR=
POCKET_SELL_SELECTOR=
POCKET_AMOUNT_SELECTOR=

# Credenciales de Telegram API (my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=signal_reader
TELEGRAM_BACKFILL_MINUTES=15
TELEGRAM_BACKFILL_LIMIT=40
APP_TELEGRAM_REALTIME_ONLY=false

# Chats a escuchar: usernames, IDs o nombres separados por coma
